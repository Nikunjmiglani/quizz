generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CREATOR
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  attempts  Attempt[]
  quizzes   Quiz[]   @relation("CreatorQuizzes")

  @@index([role])
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?

  creatorId   String
  creator     User       @relation("CreatorQuizzes", fields: [creatorId], references: [id])

  questions   Question[]
  attempts    Attempt[]

  createdAt   DateTime   @default(now())

  @@index([creatorId])
  @@index([createdAt])
}

model Question {
  id        String   @id @default(cuid())
  question  String
  options   Json
  answer    String

  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Attempt {
  id          String   @id @default(cuid())

  userId      String
  quizId      String

  score       Int
  total       Int

  suspicious  Boolean  @default(false)

  startedAt   DateTime @default(now())
  endedAt     DateTime?
   createdAt   DateTime @default(now())

  // relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([score])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}